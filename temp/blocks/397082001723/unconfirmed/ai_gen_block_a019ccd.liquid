{% doc %}
  @prompt
    make me 4 text cards
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-text-cards__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    width: 100%;
  }

  .ai-text-cards__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-text-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-text-cards__icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-text-cards__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-text-cards__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-cards__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-text-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-cards__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign title_key = 'card_' | append: i | append: '_title'
        assign description_key = 'card_' | append: i | append: '_description'
        assign icon_key = 'card_' | append: i | append: '_icon'
        
        assign card_title = block.settings[title_key]
        assign card_description = block.settings[description_key]
        assign card_icon = block.settings[icon_key]
      %}
      
      <div class="ai-text-cards__card-{{ ai_gen_id }}">
        {% if card_icon != blank %}
          <div class="ai-text-cards__icon-{{ ai_gen_id }}">
            {{ card_icon }}
          </div>
        {% endif %}
        
        {% if card_title != blank %}
          <h3 class="ai-text-cards__title-{{ ai_gen_id }}">
            {{ card_title }}
          </h3>
        {% endif %}
        
        {% if card_description != blank %}
          <div class="ai-text-cards__description-{{ ai_gen_id }}">
            {{ card_description }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

