{% doc %}
  @prompt
    Build an interactive "Find Your Account Manager" page for our wholesale section.
    Layout: U.S. map on left, Account Manager contact card on right (stacks vertically on mobile).
    Header:
    
    Title: Find your Account Manager
    Subheading: Click your state to meet your dedicated SIV Account Manager — your go-to for orders, restocks, launches, and everything in between.
    Footer line below map: Prefer to skip the map? Email wholesale@sivcare.com and we'll route you to your Account Manager.
    
    Map: Interactive SVG of all 50 states + DC on a black background. States are color-coded by Account Manager (legend in corner). Hover dims the state; click highlights it with a white border and loads that manager's card on the right.
    Territories & colors:
    
    Crosby Wolownik (blue #7FA8D1): TX, OK, AR, LA, MS, AL, GA, FL, TN, KY, SC, NC
    Leah Konkiel (pink #F2A3B0): MN, WI, MI, IA, NE, KS, MO, IL, IN, OH, WV, VA, PA, NY, VT, NH, ME, MA, CT, RI, NJ, DE, MD, DC
    Devonie Bowman (green #7FB896): WA, OR, ID, MT, WY, UT, CO, NM, ND, SD
    Cassandra [LAST] (tan #E8C391): CA, NV, AZ
    Unassigned (gray): AK, HI
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-account-manager-finder-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-account-manager-finder__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-account-manager-finder__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-account-manager-finder__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ai-account-manager-finder__content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-account-manager-finder__map-section-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-account-manager-finder__map-container-{{ ai_gen_id }} {
    background-color: #000000;
    border-radius: 8px;
    padding: 40px 20px;
    position: relative;
  }

  .ai-account-manager-finder__map-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }} {
    cursor: pointer;
    transition: opacity 0.2s ease, stroke 0.2s ease;
    stroke: #000000;
    stroke-width: 1;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }}.active {
    stroke: #ffffff;
    stroke-width: 2;
  }

  .ai-account-manager-finder__legend-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background-color: rgba(255, 255, 255, 0.95);
    padding: 16px;
    border-radius: 6px;
    font-size: 13px;
  }

  .ai-account-manager-finder__legend-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ai-account-manager-finder__legend-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-account-manager-finder__legend-color-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    border-radius: 3px;
    border: 1px solid #ccc;
  }

  .ai-account-manager-finder__card-section-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-account-manager-finder__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: 8px;
    padding: 32px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    min-height: 400px;
  }

  .ai-account-manager-finder__card-placeholder-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #999;
    font-size: 16px;
    min-height: 400px;
  }

  .ai-account-manager-finder__card-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .ai-account-manager-finder__card-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-account-manager-finder__card-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-account-manager-finder__manager-name-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-account-manager-finder__manager-title-{{ ai_gen_id }} {
    font-size: 16px;
    color: #666;
    margin: 0 0 24px;
  }

  .ai-account-manager-finder__manager-states-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .ai-account-manager-finder__manager-contact-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-account-manager-finder__contact-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-account-manager-finder__contact-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-account-manager-finder__contact-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-account-manager-finder__contact-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-account-manager-finder__footer-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-account-manager-finder__footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-account-manager-finder__footer-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 989px) {
    .ai-account-manager-finder__content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-account-manager-finder__card-section-{{ ai_gen_id }} {
      position: static;
    }

    .ai-account-manager-finder__legend-{{ ai_gen_id }} {
      position: static;
      margin-top: 20px;
    }
  }
{% endstyle %}

