{% doc %}
  @prompt
    Build an interactive "Find Your Account Manager" page for our wholesale section.
    Layout: U.S. map on left, Account Manager contact card on right (stacks vertically on mobile).
    Header:
    
    Title: Find your Account Manager
    Subheading: Click your state to meet your dedicated SIV Account Manager — your go-to for orders, restocks, launches, and everything in between.
    Footer line below map: Prefer to skip the map? Email wholesale@sivcare.com and we'll route you to your Account Manager.
    
    Map: Interactive SVG of all 50 states + DC on a black background. States are color-coded by Account Manager (legend in corner). Hover dims the state; click highlights it with a white border and loads that manager's card on the right.
    Territories & colors:
    
    Crosby Wolownik (blue #7FA8D1): TX, OK, AR, LA, MS, AL, GA, FL, TN, KY, SC, NC
    Leah Konkiel (pink #F2A3B0): MN, WI, MI, IA, NE, KS, MO, IL, IN, OH, WV, VA, PA, NY, VT, NH, ME, MA, CT, RI, NJ, DE, MD, DC
    Devonie Bowman (green #7FB896): WA, OR, ID, MT, WY, UT, CO, NM, ND, SD
    Cassandra [LAST] (tan #E8C391): CA, NV, AZ
    Unassigned (gray): AK, HI, This is of the United States. That does not look like the United States. Account Manager card (black background, white text):
    
    State name (small caps, top)
    Full name (large)
    "ACCOUNT MANAGER" label
    Email with envelope icon (mailto link)
    Phone with phone icon (tel link)
    Closer: Drop [First Name] a line anytime — they'll get you set up.
    
    Contact info:
    NameEmailPhoneCrosby Wolownikcwolownik@sivcare.com+1 (770) 370-9039Leah Konkiellkonkiel@sivcare.com+1 (443) 239-5042Devonie Bowmandbowman@sivcare.com971-244-3493Cassandra [LAST][email][phone]
    Unassigned card (AK, HI): Same black style. Heading: This territory is open. Body: Reach out and we'll connect you with the right person. Button: wholesale@sivcare.com (mailto).
    Empty state (before click): Light gray card with pin icon, Click your state, and Select your state on the map to see your dedicated Account Manager.
    Accessibility: States keyboard-navigable, aria-labels on each, aria-live region for card updates.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-account-manager-finder-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-account-manager-finder__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-account-manager-finder__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-account-manager-finder__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ai-account-manager-finder__content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-account-manager-finder__map-section-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-account-manager-finder__map-container-{{ ai_gen_id }} {
    background-color: #000000;
    border-radius: 8px;
    padding: 40px 20px;
    position: relative;
  }

  .ai-account-manager-finder__map-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }} {
    cursor: pointer;
    transition: opacity 0.2s ease, stroke 0.2s ease;
    stroke: #000000;
    stroke-width: 1;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }}:hover,
  .ai-account-manager-finder__state-{{ ai_gen_id }}:focus {
    opacity: 0.7;
    outline: none;
  }

  .ai-account-manager-finder__state-{{ ai_gen_id }}.active {
    stroke: #ffffff;
    stroke-width: 2;
  }

  .ai-account-manager-finder__legend-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background-color: rgba(255, 255, 255, 0.95);
    padding: 16px;
    border-radius: 6px;
    font-size: 13px;
  }

  .ai-account-manager-finder__legend-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ai-account-manager-finder__legend-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-account-manager-finder__legend-color-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    border-radius: 3px;
    border: 1px solid #ccc;
  }

  .ai-account-manager-finder__card-section-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-account-manager-finder__card-{{ ai_gen_id }} {
    background-color: #000000;
    border-radius: 8px;
    padding: 40px;
    min-height: 400px;
  }

  .ai-account-manager-finder__card-placeholder-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #cccccc;
    min-height: 400px;
  }

  .ai-account-manager-finder__card-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    margin-bottom: 20px;
    opacity: 0.5;
  }

  .ai-account-manager-finder__card-placeholder-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
    color: #ffffff;
  }

  .ai-account-manager-finder__card-placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
    color: #999999;
  }

  .ai-account-manager-finder__card-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-account-manager-finder__card-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-account-manager-finder__state-name-{{ ai_gen_id }} {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #999999;
    margin: 0 0 16px;
  }

  .ai-account-manager-finder__manager-name-{{ ai_gen_id }} {
    font-size: 36px;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ai-account-manager-finder__manager-title-{{ ai_gen_id }} {
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #999999;
    margin: 0 0 32px;
  }

  .ai-account-manager-finder__manager-contact-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ai-account-manager-finder__contact-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-account-manager-finder__contact-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: #ffffff;
  }

  .ai-account-manager-finder__contact-link-{{ ai_gen_id }} {
    color: #ffffff;
    text-decoration: none;
    font-size: 16px;
  }

  .ai-account-manager-finder__contact-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-account-manager-finder__closer-{{ ai_gen_id }} {
    font-size: 15px;
    color: #cccccc;
    line-height: 1.6;
    margin: 0;
  }

  .ai-account-manager-finder__unassigned-heading-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 16px;
  }

  .ai-account-manager-finder__unassigned-body-{{ ai_gen_id }} {
    font-size: 16px;
    color: #cccccc;
    margin: 0 0 24px;
    line-height: 1.6;
  }

  .ai-account-manager-finder__unassigned-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 28px;
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .ai-account-manager-finder__unassigned-button-{{ ai_gen_id }}:hover {
    background-color: #f0f0f0;
  }

  .ai-account-manager-finder__footer-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-account-manager-finder__footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-account-manager-finder__footer-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-account-manager-finder__live-region-{{ ai_gen_id }} {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media screen and (max-width: 989px) {
    .ai-account-manager-finder__content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-account-manager-finder__card-section-{{ ai_gen_id }} {
      position: static;
    }

    .ai-account-manager-finder__legend-{{ ai_gen_id }} {
      position: static;
      margin-top: 20px;
    }

    .ai-account-manager-finder__manager-name-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }
{% endstyle %}

