<script>
  (function() {
    class AccountManagerFinder{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.states = this.querySelectorAll('.ai-account-manager-finder__state-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-account-manager-finder__card-content-{{ ai_gen_id }}');
        this.placeholder = this.querySelector('.ai-account-manager-finder__card-placeholder-{{ ai_gen_id }}');
        this.liveRegion = this.querySelector('.ai-account-manager-finder__live-region-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.states.forEach(state => {
          state.addEventListener('click', (e) => {
            this.handleStateSelection(state);
          });

          state.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              this.handleStateSelection(state);
            }
          });
        });
      }

      handleStateSelection(state) {
        const manager = state.getAttribute('data-manager');
        const stateName = state.getAttribute('data-state-name');
        this.showManager(manager, stateName);
        this.highlightState(state);
        this.announceSelection(stateName, manager);
      }

      showManager(manager, stateName) {
        this.placeholder.style.display = 'none';
        this.cards.forEach(card => {
          if (card.getAttribute('data-manager') === manager) {
            card.classList.add('active');
            const stateNameElement = card.querySelector('.ai-account-manager-finder__state-name-{{ ai_gen_id }}');
            if (stateNameElement) {
              stateNameElement.textContent = stateName;
            }
          } else {
            card.classList.remove('active');
          }
        });
      }

      highlightState(selectedState) {
        this.states.forEach(state => {
          state.classList.remove('active');
        });
        selectedState.classList.add('active');
      }

      announceSelection(stateName, manager) {
        const managerNames = {
          'crosby': 'Crosby Wolownik',
          'leah': 'Leah Konkiel',
          'devonie': 'Devonie Bowman',
          'cassandra': 'Cassandra',
          'unassigned': 'Unassigned territory'
        };
        const managerName = managerNames[manager] || 'Account Manager';
        this.liveRegion.textContent = stateName + ' selected. Showing ' + managerName;
      }
    }

    customElements.define('account-manager-finder-{{ ai_gen_id }}', AccountManagerFinder{{ ai_gen_id }});
  })();
</script>

