            "custom_html": "<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&amp;display=swap\" rel=\"stylesheet\">\n<style>\n  .siv-wholesale{background:#0E0E0E;border-radius:12px;padding:48px 5%;box-sizing:border-box;width:100%;}\n  .siv-wholesale .head-wrap{text-align:center;max-width:640px;margin:0 auto;}\n  .siv-wholesale .eyebrow{margin:0 0 14px;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#FFF;}\n  .siv-wholesale h2{margin:0 0 16px;font-family:'Bebas Neue',sans-serif;font-weight:400;font-size:46px;line-height:.95;letter-spacing:.02em;color:#FFF;}\n  .siv-wholesale .lede{margin:0 0 8px;font-size:16px;line-height:1.6;color:#FFF;}\n  .siv-wholesale .note{margin:0;font-size:14px;color:#FFF;}\n  .siv-wholesale .region-label{text-align:center;margin:36px 0 18px;font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:#FFF;font-weight:600;}\n  .siv-wholesale .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;max-width:1100px;margin:0 auto;}\n  .siv-wholesale .card{background:#2A2A28;border-radius:10px;border:1px solid #3A3A37;border-top:4px solid #FFFFFF;padding:24px 22px;}\n  .siv-wholesale .card p.r-name{margin:0 0 8px;font-size:17px;font-weight:600;color:#FFF;}\n  .siv-wholesale .card p.r-desc{margin:0 0 14px;font-size:14px;line-height:1.5;color:#C9C4BC;}\n  .siv-wholesale .card a{font-size:14px;font-weight:600;text-decoration:underline;text-underline-offset:3px;word-break:break-word;color:#FFFFFF;}\n  .siv-wholesale .closer{text-align:center;margin:30px 0 0;font-size:15px;color:#FFF;}\n  @media(max-width:560px){\n    .siv-wholesale{padding:24px 16px;}\n    .siv-wholesale h2{font-size:32px;margin:0 0 10px;}\n    .siv-wholesale .eyebrow{margin:0 0 8px;}\n    .siv-wholesale .lede{font-size:14px;line-height:1.45;margin:0 0 6px;}\n    .siv-wholesale .note{font-size:13px;}\n    .siv-wholesale .region-label{font-size:12px;margin:20px 0 12px;}\n    .siv-wholesale .grid{grid-template-columns:1fr;gap:10px;}\n    